---
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Base from "../layouts/Base.astro";

const cambridgeLogoSrc = "/images/Cambridge%20logo.png";
const schoolLogoSrc = "/images/School%20logo.png";
const heroImageSrc = "/images/hero%20image.jpg";

const learningPathways = [
  {
    name: "iPlay",
    gradeRange: "Pre KG – Grade 2",
    stats: ["Brain development", "24 Skills", "3 Languages"],
    placeholder: "[iPLAY IMAGE]",
    icon: "✦"
  },
  {
    name: "iDiscover",
    gradeRange: "Grade 3–7",
    stats: ["24 Projects", "Passion Discovery", "8 Professional Skills"],
    placeholder: "[iDISCOVER IMAGE]",
    icon: "✧"
  },
  {
    name: "iLead",
    gradeRange: "Grade 8–12",
    stats: ["Leadership", "Career Readiness", "Internships"],
    placeholder: "[iLEAD IMAGE]",
    icon: "✺"
  }
];

const upcomingEvents = [
  {
    title: "Costume Day Celebration",
    date: "3 July 2026 • 10:00 AM – 11:00 AM",
    description: "A joyful celebration of imagination and self-expression where students dress up and shine with confidence.",
    imageSrc: "/images/Event%20image%201.png",
    imageLabel: "[COSTUME DAY EVENT IMAGE]"
  },
  {
    title: "Onam Celebration",
    date: "August 2026",
    description: "A warm celebration of tradition, togetherness, and gratitude filled with culture, music, and shared memories.",
    imageSrc: "/images/Event%20image%202.png",
    imageLabel: "[ONAM CELEBRATION IMAGE]"
  },
  {
    title: "Stargazing Evening",
    date: "August 2026 • 4:00 PM – 7:00 PM",
    description: "An enchanting evening of discovery, storytelling, and wonder under the stars for curious young minds.",
    imageSrc: "/images/Event%20image%203.png",
    imageLabel: "[STARGAZING EVENT IMAGE]"
  }
];

const galleryLabels = [
  "[GALLERY IMAGE 1]",
  "[GALLERY IMAGE 2]",
  "[GALLERY IMAGE 3]",
  "[GALLERY IMAGE 4]",
  "[GALLERY IMAGE 5]",
  "[GALLERY IMAGE 6]"
];
---

<Base
  title="Wisdom Wealth International School, Trichy | Cambridge CIE School"
  description="WWIS Trichy offers Cambridge CIE learning, iPlay, iDiscover, iLead, and Individual Learning Plans from Pre-KG to Grade 12."
  showHeaderLogos={true}
  cambridgeLogoSrc={cambridgeLogoSrc}
  schoolLogoSrc={schoolLogoSrc}
>
  <PageHero
    title="Welcome to WWIS"
    text="WWIS is committed to providing quality education, academic excellence, character development, and holistic learning opportunities for every student."
    variant="home"
    centered={true}
    heroImageSrc={heroImageSrc}
    cambridgeLogoSrc={cambridgeLogoSrc}
    schoolLogoSrc={schoolLogoSrc}
    primaryLabel="Explore Our Programs"
    primaryHref="/our-programs"
    secondaryLabel="Find Us"
    secondaryHref="/find-us"
  />

  <section class="pathways-section">
    <SectionHeader
      title="Learning Pathways"
      text="A stage-wise journey from play to leadership, designed to support each learner with confidence and purpose."
    />
    <div class="pathways-grid">
      {learningPathways.map((pathway) => (
        <article class="pathway-card fade-up">
          <ImagePlaceholder
            label={pathway.placeholder}
            src={pathway.name === "iPlay" ? "/images/iplay%20image.jpg" : pathway.name === "iDiscover" ? "/images/idiscover%20image.jpg" : "/images/ilead%20image.jpg"}
            aspectRatio="16 / 10"
            class="pathway-card__image"
            loading="lazy"
          />
          <div class="pathway-card__body">
            <div class="pathway-card__icon" aria-hidden="true">{pathway.icon}</div>
            <h3>{pathway.name}</h3>
            <p class="pathway-card__grade">{pathway.gradeRange}</p>
            <ul class="pathway-card__stats">
              {pathway.stats.map((stat) => (
                <li>{stat}</li>
              ))}
            </ul>
            <a class="pathway-card__link" href="/our-programs">Learn more →</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="events-section soft-band">
    <SectionHeader
      title="Upcoming Events"
      text="Stay updated with the latest school activities, celebrations, competitions, educational programmes and announcements."
    />
    <div class="events-grid">
      {upcomingEvents.map((event) => (
        <article class="event-card fade-up">
          <ImagePlaceholder
            label={event.imageLabel}
            src={event.imageSrc}
            aspectRatio="16 / 10"
            class="event-card__image"
            loading="lazy"
          />
          <div class="event-card__body">
            <h3>{event.title}</h3>
            <p class="event-card__date">{event.date}</p>
            <p class="event-card__description">{event.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="gallery-section">
    <SectionHeader
      title="Gallery"
      text="Beyond textbooks and exams, we create memorable learning experiences that bring curiosity, confidence, and celebration to life."
    />
    <div class="gallery-masonry">
      {galleryLabels.map((label, index) => (
        <ImagePlaceholder
          label={label}
          src={`/images/Gallery%20${index + 1}.png`}
          aspectRatio={index === 0 || index === 3 ? "4 / 5" : "4 / 3"}
          class:list={["gallery-item", `gallery-item--${index + 1}`]}
          loading="lazy"
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .pathways-section {
    background: linear-gradient(135deg, var(--ivory) 0%, #fdfcf7 100%);
  }

  .pathways-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .pathway-card {
    background: rgba(255, 255, 255, 0.95);
    border: 1.5px solid var(--line-gold);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .pathway-card:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-md);
    transform: translateY(-6px);
  }

  .pathway-card :global(.pathway-card__image) {
    border-radius: 0;
    border-bottom: 1.5px dashed var(--line-gold);
  }

  .pathway-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 12px;
    padding: 26px 28px 30px;
  }

  .pathway-card__icon {
    align-items: center;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    border-radius: 50%;
    color: var(--emerald);
    display: inline-flex;
    font-size: 1.05rem;
    font-weight: 800;
    height: 46px;
    justify-content: center;
    width: 46px;
    box-shadow: 0 10px 24px rgba(212, 175, 55, 0.25);
  }

  .pathway-card h3 {
    font-size: clamp(1.3rem, 2vw, 1.55rem);
  }

  .pathway-card__grade {
    color: var(--gold-text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pathway-card__stats {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 8px;
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
  }

  .pathway-card__stats li {
    background: var(--ivory-2);
    border: 1px solid var(--line-gold);
    border-radius: var(--radius-sm);
    color: var(--emerald);
    font-size: 0.88rem;
    font-weight: 600;
    padding: 9px 14px;
  }

  .pathway-card__link {
    color: var(--emerald);
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: 8px;
    text-decoration: none;
    transition: color 0.2s;
  }

  .pathway-card__link:hover {
    color: var(--gold-text);
  }

  .events-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .event-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(255,252,244,0.97) 100%);
    border: 1.5px solid var(--line-gold);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .event-card:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-md);
    transform: translateY(-6px);
  }

  .event-card :global(.event-card__image) {
    border-radius: 0;
    border-bottom: 1.5px dashed var(--line-gold);
    min-height: 220px;
  }

  .event-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    padding: 26px 28px 30px;
  }

  .event-card h3 {
    font-size: 1.2rem;
    margin: 0;
  }

  .event-card__date {
    color: var(--gold-text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .event-card__description {
    color: var(--charcoal-2);
    flex: 1;
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .gallery-masonry {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: auto auto;
  }

  .gallery-masonry :global(.gallery-item) {
    min-height: 220px;
  }

  .gallery-masonry :global(.gallery-item--1) {
    grid-column: 1;
    grid-row: 1 / span 2;
  }

  .gallery-masonry :global(.gallery-item--2) {
    grid-column: 2;
    grid-row: 1;
  }

  .gallery-masonry :global(.gallery-item--3) {
    grid-column: 3;
    grid-row: 1;
  }

  .gallery-masonry :global(.gallery-item--4) {
    grid-column: 2;
    grid-row: 2;
  }

  .gallery-masonry :global(.gallery-item--5) {
    grid-column: 3;
    grid-row: 2;
  }

  .gallery-masonry :global(.gallery-item--6) {
    display: none;
  }

  @media (min-width: 901px) {
    .gallery-masonry {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .gallery-masonry :global(.gallery-item--1) {
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    .gallery-masonry :global(.gallery-item--2) {
      grid-column: 2;
      grid-row: 1;
    }

    .gallery-masonry :global(.gallery-item--3) {
      grid-column: 3;
      grid-row: 1;
    }

    .gallery-masonry :global(.gallery-item--4) {
      grid-column: 4;
      grid-row: 1 / span 2;
    }

    .gallery-masonry :global(.gallery-item--5) {
      grid-column: 2;
      grid-row: 2;
    }

    .gallery-masonry :global(.gallery-item--6) {
      display: flex;
      grid-column: 3;
      grid-row: 2;
    }
  }

  @media (max-width: 900px) {
    .pathways-grid,
    .events-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gallery-masonry {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gallery-masonry :global(.gallery-item--1),
    .gallery-masonry :global(.gallery-item--4) {
      grid-row: auto;
    }

    .gallery-masonry :global(.gallery-item--6) {
      display: flex;
      grid-column: auto;
      grid-row: auto;
    }
  }

  @media (max-width: 560px) {
    .pathways-grid,
    .events-grid,
    .gallery-masonry {
      grid-template-columns: 1fr;
    }

    .gallery-masonry :global(.gallery-item--1),
    .gallery-masonry :global(.gallery-item--4) {
      grid-row: auto;
    }
  }
</style>
