---
import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";
import { contactInfo } from "../data/school";
---

<Base
  title="Admission Form | WWIS Trichy"
  description="Submit a private admission enquiry to WWIS with your child's details, parent information, and school preferences."
  pageType="ContactPage"
>
  <PageHero
    eyebrow="Admission Form"
    title="Apply for Admission"
    text="Share your enquiry securely with the WWIS admissions team. Every field below helps us understand your child’s needs and next steps."
    centered={true}
    primaryLabel="Back to Find Us"
    primaryHref="/find-us"
    secondaryLabel="Contact Admissions"
    secondaryHref={`mailto:${contactInfo.email}`}
  />

  <section class="form-section">
    <form class="admission-form fade-up" id="admission-form">
      <div class="form-grid">
        <label>
          <span>Child's Name</span>
          <input name="childName" required />
        </label>
        <label>
          <span>Date of Birth</span>
          <input name="dob" type="date" required />
        </label>
        <label>
          <span>Gender</span>
          <select name="gender" required>
            <option value="">Select</option>
            <option>Male</option>
            <option>Female</option>
            <option>Other</option>
          </select>
        </label>
        <label>
          <span>Grade Applying For</span>
          <input name="grade" required />
        </label>
        <label>
          <span>Current School</span>
          <input name="currentSchool" required />
        </label>
        <label>
          <span>Parent/Guardian Name</span>
          <input name="parentName" required />
        </label>
        <label>
          <span>Contact Number</span>
          <input name="phone" type="tel" required />
        </label>
        <label>
          <span>Email Address</span>
          <input name="email" type="email" required />
        </label>
        <label>
          <span>Address</span>
          <textarea name="address" rows="3" required></textarea>
        </label>
        <label>
          <span>Medical Information</span>
          <textarea name="medicalInfo" rows="3"></textarea>
        </label>
        <label>
          <span>Remarks</span>
          <textarea name="remarks" rows="3"></textarea>
        </label>
      </div>
      <button class="submit-button" type="submit">Submit Enquiry</button>
      <p class="form-note" id="form-note">Your enquiry will be sent privately to the WWIS admissions team.</p>
    </form>
  </section>
</Base>

<script>
  const form = document.getElementById("admission-form") as HTMLFormElement | null;
  const note = document.getElementById("form-note");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>("[required]");
    const missing = Array.from(requiredFields).some((field) => !field.value.trim());

    if (missing) {
      if (note) {
        note.textContent = "Please complete all required fields before submitting.";
        note.classList.add("is-error");
      }
      return;
    }

    const formData = new FormData(form);
    const subject = encodeURIComponent("New WWIS Admission Enquiry");
    const body = encodeURIComponent(
      [
        `Child's Name: ${formData.get("childName") ?? ""}`,
        `Date of Birth: ${formData.get("dob") ?? ""}`,
        `Gender: ${formData.get("gender") ?? ""}`,
        `Grade Applying For: ${formData.get("grade") ?? ""}`,
        `Current School: ${formData.get("currentSchool") ?? ""}`,
        `Parent/Guardian Name: ${formData.get("parentName") ?? ""}`,
        `Contact Number: ${formData.get("phone") ?? ""}`,
        `Email Address: ${formData.get("email") ?? ""}`,
        `Address: ${formData.get("address") ?? ""}`,
        `Medical Information: ${formData.get("medicalInfo") ?? ""}`,
        `Remarks: ${formData.get("remarks") ?? ""}`
      ].join("\n")
    );

    window.location.href = `mailto:rootadmin@wwistrichy.com?subject=${subject}&body=${body}`;

    if (note) {
      note.textContent = "Your enquiry has been prepared for the WWIS admissions inbox. Please send the email to complete the submission.";
      note.classList.remove("is-error");
    }
    form.reset();
  });
</script>

<style>
  .form-section {
    padding-top: 10px;
  }

  .admission-form {
    background: rgba(255, 255, 255, 0.98);
    border: 1.25px solid var(--border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    margin: 0 auto;
    max-width: 860px;
    padding: 32px;
    background: linear-gradient(180deg, var(--card-bg), rgba(255,255,255,0.6));
  }

  .form-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  label {
    display: grid;
    gap: 8px;
  }

  label span {
    color: var(--text-primary);
    font-weight: 700;
  }

  input,
  select,
  textarea {
    background: var(--soft-white);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-sm);
    font: inherit;
    padding: 12px 14px;
  }

  textarea {
    min-height: 92px;
    resize: vertical;
  }

  .submit-button {
    background: linear-gradient(135deg, var(--royal-blue) 0%, var(--navy-blue) 100%);
    border: 0;
    border-radius: var(--radius-pill);
    color: var(--white-pure);
    cursor: pointer;
    font-weight: 800;
    margin-top: 22px;
    padding: 14px 24px;
    box-shadow: var(--shadow-md);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .submit-button:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }

  .form-note {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 12px;
  }

  .form-note.is-error {
    color: var(--color-error);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
