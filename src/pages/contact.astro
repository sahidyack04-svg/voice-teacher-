---
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Base from "../layouts/Base.astro";
import { contactInfo, schoolName } from "../data/school";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Wisdom Wealth International School",
  mainEntity: {
    "@type": "EducationalOrganization",
    name: schoolName,
    telephone: contactInfo.phone,
    email: contactInfo.email,
    address: contactInfo.address
  }
};
---

<Base
  title="Contact WWIS | Admissions, Campus Visit, Fee Request"
  description="Contact Wisdom Wealth International School Trichy for admissions, fee structure requests, campus visits, transport questions, and callback support."
  pageType="ContactPage"
>
  <PageHero
    eyebrow="Contact"
    title="Talk to the WWIS admissions team"
    text="Reach WWIS for campus visits, admissions counseling, fee structure requests, transport questions, and callback support."
    primaryLabel="Call Admissions"
    primaryHref={`tel:${contactInfo.phoneHref}`}
    secondaryLabel="Email Admissions"
    secondaryHref={`mailto:${contactInfo.email}`}
  />

  <section>
    <div class="grid grid-2">
      <address class="card">
        <h2>{schoolName}</h2>
        <p>{contactInfo.address}</p>
        <p><strong>Phone:</strong> <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a></p>
        <p><strong>Email:</strong> <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a></p>
        <p><strong>Hours:</strong> {contactInfo.hours}</p>
        <p><strong>Location:</strong> {contactInfo.mapLabel}</p>
      </address>
      <div class="card">
        <h2>Admissions support</h2>
        <p>
          Use this page for visit booking, callback requests, fee enquiries, transport questions, and program guidance.
          Complex questions should be sent to the admissions email for staff follow-up.
        </p>
        <div class="actions">
          <a class="button button-primary" href="#visit">Book Visit</a>
          <a class="button button-light" href="/admissions#fee-request">Request Fees</a>
        </div>
      </div>
    </div>
  </section>

  <section class="soft-band" id="visit">
    <div class="grid grid-2">
      <div>
        <SectionHeader
          eyebrow="Visit booking"
          title="Request a campus visit or callback"
          text="Share the child grade, preferred visit day, and contact details. The admissions team will confirm availability during school hours."
        />
      </div>
      <form class="form-panel" name="visit-request" method="post" action={`mailto:${contactInfo.email}`}>
        <div class="form-grid">
          <p>
            <label for="name">Parent name</label>
            <input id="name" name="name" required />
          </p>
          <p>
            <label for="contact-phone">Phone</label>
            <input id="contact-phone" name="phone" required />
          </p>
          <p>
            <label for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" required />
          </p>
          <p>
            <label for="child-grade">Child grade</label>
            <input id="child-grade" name="child-grade" required />
          </p>
          <p>
            <label for="inquiry-type">Inquiry type</label>
            <select id="inquiry-type" name="inquiry-type">
              <option>Campus visit</option>
              <option>Admissions counseling</option>
              <option>Fee structure</option>
              <option>Transport question</option>
              <option>Callback request</option>
            </select>
          </p>
          <p>
            <label for="preferred-time">Preferred time</label>
            <input id="preferred-time" name="preferred-time" placeholder="Example: Saturday morning" />
          </p>
          <p class="full">
            <label for="contact-message">Message</label>
            <textarea id="contact-message" name="message"></textarea>
          </p>
        </div>
        <button class="button button-primary" type="submit">Send Request</button>
      </form>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
</Base>
