---
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
import PageHero from "../components/PageHero.astro";
import Base from "../layouts/Base.astro";

const achievements = [
  {
    title: "Story Books",
    body: "Students develop confidence through storytelling, reading, expression, and creative writing activities that strengthen imagination and communication.",
    image: "[Story Books Image]"
  },
  {
    title: "Culinary Arts",
    body: "Hands-on kitchen experiences encourage creativity, hygiene, teamwork, and practical life skills while helping students explore nutrition and presentation.",
    image: "[Culinary Arts Image]"
  },
  {
    title: "Art and Craft",
    body: "Creative projects foster innovation, visual expression, patience, and collaborative learning in a joyful and inspiring environment.",
    image: "[Art and Craft Image]"
  },
  {
    title: "Website Development",
    body: "Students learn digital skills by building projects, exploring design thinking, and communicating ideas through thoughtful online experiences.",
    image: "[Website Development Image]"
  },
  {
    title: "Product Designing",
    body: "Design thinking helps students turn ideas into practical solutions through problem-solving, creativity, experimentation, and functional planning.",
    image: "[Product Designing Image]"
  }
];
---

<Base
  title="Student Achievements | WWIS Trichy"
  description="Discover how WWIS celebrates student achievements across storytelling, culinary arts, creativity, digital learning, and product design."
  pageType="AboutPage"
>
  <PageHero
    eyebrow="Student Achievements"
    title="Every achievement is a meaningful moment of growth"
    text="At WWIS, achievements are celebrated as evidence of confidence, curiosity, perseverance, and joyful progress across academics and talents."
    primaryLabel="Back to About Us"
    primaryHref="/about"
    secondaryLabel="Explore Daily Activities"
    secondaryHref="/daily-activities"
  />

  <section class="achievement-list">
    {achievements.map((item, index) => (
      <article class:list={["achievement-card fade-up", index % 2 === 1 && "achievement-card--reverse"]}>
        <div class="achievement-card__content">
          <p class="eyebrow">{item.title}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
        </div>
        <div class="achievement-card__media">
          <ImagePlaceholder label={item.image} aspectRatio="4 / 3" />
        </div>
      </article>
    ))}
  </section>
</Base>

<style>
  .achievement-list {
    display: grid;
    gap: 24px;
  }

  .achievement-card {
    align-items: center;
    background: rgba(255, 255, 255, 0.95);
    border: 1.5px solid var(--line-gold);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.8fr);
    padding: 24px;
  }

  .achievement-card--reverse {
    grid-template-columns: minmax(240px, 0.8fr) minmax(0, 1fr);
  }

  .achievement-card--reverse .achievement-card__media {
    order: 2;
  }

  .achievement-card__content {
    display: grid;
    gap: 10px;
  }

  @media (max-width: 800px) {
    .achievement-card,
    .achievement-card--reverse {
      grid-template-columns: 1fr;
    }

    .achievement-card--reverse .achievement-card__media {
      order: 0;
    }
  }
</style>
