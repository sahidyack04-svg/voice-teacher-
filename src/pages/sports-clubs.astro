---
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Base from "../layouts/Base.astro";
import { clubs, sportsStrengths } from "../data/school";
---

<Base
  title="Sports and Clubs | WWIS Trichy"
  description="WWIS presents sports as a major strength with structured coaching, inter-school competitions, robotics, coding, music, dance, art, chess, debate, public speaking, entrepreneurship, environment, and community service."
>
  <PageHero
    eyebrow="Sports and clubs"
    title="Structured coaching, competitions, and student leadership"
    text="Sports and co-curricular activities at WWIS support confidence, discipline, teamwork, expression, and future-ready skills beyond the classroom."
    primaryLabel="Book a Visit"
    primaryHref="/contact#visit"
    secondaryLabel="Explore Admissions"
    secondaryHref="/admissions"
  />

  <section>
    <SectionHeader
      eyebrow="Sports"
      title="A major school strength"
      text="Sports should be presented as structured student development, not only casual activity."
    />
    <div class="grid grid-3">
      {sportsStrengths.map((strength) => (
        <article class="card">
          <h2>{strength}</h2>
          <p>Part of the WWIS sports experience for building physical confidence, focus, and team spirit.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="soft-band">
    <SectionHeader
      eyebrow="Clubs"
      title="Co-curricular pathways for exploration and expression"
      text="Clubs give students structured ways to discover interests, practice communication, and build confidence."
    />
    <ul class="tag-list">
      {clubs.map((club) => <li>{club}</li>)}
    </ul>
  </section>
</Base>
