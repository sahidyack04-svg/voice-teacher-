---
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Base from "../layouts/Base.astro";
import { galleryCategories } from "../data/school";
---

<Base
  title="Gallery | WWIS Trichy"
  description="WWIS gallery categories for approved campus, classroom, event, sports, laboratory, student achievement, and faculty interaction photos and videos."
>
  <PageHero
    eyebrow="Gallery"
    title="Approved WWIS moments, organized for parents"
    text="The gallery is prepared for official WWIS photos and videos from the campus, classrooms, events, sports, laboratories, achievements, and faculty interactions."
    primaryLabel="Book a Campus Visit"
    primaryHref="/contact#visit"
    secondaryLabel="View Facilities"
    secondaryHref="/facilities"
  />

  <section>
    <SectionHeader
      eyebrow="Media categories"
      title="Real school content belongs here"
      text="Use only approved WWIS media in the final production gallery. This structure avoids presenting generic images as official school photography."
    />
    <div class="grid grid-3">
      {galleryCategories.map((category) => (
        <article class="card media-placeholder">
          <span aria-hidden="true"></span>
          <h2>{category}</h2>
          <p>Add approved WWIS {category.toLowerCase()} photos or videos under `public/assets/gallery/`.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="soft-band">
    <SectionHeader
      eyebrow="Asset guidance"
      title="Recommended media before launch"
      text="Add a campus exterior, classroom learning, science lab, computer lab, sports coaching, event, student achievement, and faculty interaction image set for the strongest parent trust signal."
    />
  </section>
</Base>

<style>
  .media-placeholder span {
    background:
      linear-gradient(135deg, rgba(0, 123, 122, 0.18), rgba(215, 155, 43, 0.18)),
      repeating-linear-gradient(45deg, rgba(16, 36, 63, 0.1) 0 1px, transparent 1px 16px);
    display: block;
    height: 180px;
    margin: -24px -24px 20px;
  }
</style>
