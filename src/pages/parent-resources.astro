---
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Base from "../layouts/Base.astro";
import { contactInfo, parentResources } from "../data/school";
---

<Base
  title="Parent Resources | WWIS Trichy"
  description="Access WWIS parent resources including academic calendar, circulars, parent handbook, uniform information, transport details, downloadable forms, parent app links, and exam schedules."
>
  <PageHero
    eyebrow="Parent resources"
    title="Everything parents need in one clear place"
    text="WWIS parent resources are organized for fast access to academic updates, transport details, forms, exam schedules, and parent communication links."
    primaryLabel="Contact Admissions"
    primaryHref="/contact"
    secondaryLabel="Request Forms"
    secondaryHref={`mailto:${contactInfo.email}`}
  />

  <section>
    <SectionHeader
      eyebrow="Resource center"
      title="Parent information categories"
      text="The first release includes clear resource areas. Final PDF files, app URLs, and circular links can be connected as official assets become available."
    />
    <div class="grid grid-3">
      {parentResources.map((resource) => (
        <article class="card">
          <h2>{resource}</h2>
          <p>Official WWIS {resource.toLowerCase()} information can be added here for parent access.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="band">
    <SectionHeader
      eyebrow="Parent support"
      title="Need a current document or app link?"
      text="Parents can contact the admissions office for the latest handbook, forms, transport information, circulars, and parent app access."
    />
    <div class="actions">
      <a class="button button-primary" href={`mailto:${contactInfo.email}`}>Email WWIS</a>
      <a class="button button-secondary" href={`tel:${contactInfo.phoneHref}`}>Call Admissions</a>
    </div>
  </section>
</Base>
