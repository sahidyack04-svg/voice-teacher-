---
interface Props {
  label: string;
  aspectRatio?: string;
  class?: string;
  minHeight?: string;
  src?: string;
  alt?: string;
  loading?: "lazy" | "eager";
}

const {
  label,
  aspectRatio = "16 / 10",
  class: className = "",
  minHeight,
  src,
  alt = label,
  loading = "lazy"
} = Astro.props;
const hasImage = Boolean(src);
---

<div
  class:list={["img-placeholder", className]}
  role={hasImage ? undefined : "img"}
  aria-label={hasImage ? undefined : label}
  style={`aspect-ratio: ${aspectRatio};${minHeight ? ` min-height: ${minHeight};` : ""}`}
>
  {hasImage ? (
    <img class="img-placeholder__image" src={src} alt={alt} loading={loading} decoding="async" />
  ) : (
    <span class="img-placeholder__label">{label}</span>
  )}
</div>

<style>
  .img-placeholder {
    align-items: center;
    background: linear-gradient(180deg, var(--white-pure) 0%, rgba(250,249,248,0.6) 100%);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    color: var(--text-primary);
    display: flex;
    justify-content: center;
    overflow: hidden;
    padding: 10px;
    text-align: center;
    transition: border-color 0.26s ease, box-shadow 0.26s ease, transform 0.26s ease;
    width: 100%;
  }

  .img-placeholder:hover {
    border-color: rgba(122,184,255,0.14);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .img-placeholder__image {
    display: block;
    height: 100%;
    object-fit: contain; /* ensure full image visible, no cropping */
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 8px 26px rgba(6, 34, 58, 0.06);
  }

  .img-placeholder__label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.4;
    text-transform: uppercase;
  }
</style>
