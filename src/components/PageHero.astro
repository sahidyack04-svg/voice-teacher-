---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { eyebrow, title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero__content">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p>{text}</p>
    {(primaryLabel || secondaryLabel) && (
      <div class="hero-actions">
        {primaryLabel && primaryHref && <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>}
        {secondaryLabel && secondaryHref && <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>}
      </div>
    )}
  </div>
</section>
