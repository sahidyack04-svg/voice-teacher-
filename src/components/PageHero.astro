---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  centered?: boolean;
  variant?: "default" | "home";
  heroImageSrc?: string;
  heroImageAlt?: string;
}

const {
  eyebrow,
  title,
  text,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  centered = false,
  variant = "default",
  heroImageSrc,
  heroImageAlt = "WWIS campus hero image"
} = Astro.props;

const isHomeHero = variant === "home";
---

<section class:list={["page-hero", centered && "page-hero--centered", isHomeHero && "page-hero--home"]}>
  <div class:list={["page-hero__inner", isHomeHero && "page-hero__inner--home"]}>
    <div class="page-hero__content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p>{text}</p>
      {(primaryLabel || secondaryLabel) && (
        <div class="hero-actions">
          {primaryLabel && primaryHref && <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>}
          {secondaryLabel && secondaryHref && <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>}
        </div>
      )}
      {isHomeHero && (
        <div class="hero-highlights">
          <span>Cambridge CIE</span>
          <span>Holistic learning</span>
          <span>Global readiness</span>
        </div>
      )}
    </div>
    {isHomeHero && (
      <div class="page-hero__media">
        {heroImageSrc ? (
          <img class="page-hero__image" src={heroImageSrc} alt={heroImageAlt} loading="eager" />
        ) : (
          <div class="page-hero__placeholder" role="img" aria-label="Hero image placeholder">
            <span class="placeholder-label">[HERO IMAGE]</span>
          </div>
        )}
      </div>
    )}
  </div>
  {!isHomeHero && <div class="gold-accent-bar"></div>}
</section>
