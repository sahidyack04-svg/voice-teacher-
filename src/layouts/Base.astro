---
import Chatbot from "../components/Chatbot.astro";
import { brand, contactInfo, schoolName, schoolShortName, schoolUrl } from "../data/school";

interface Props {
  title: string;
  description: string;
  pageType?: "WebPage" | "AboutPage" | "ContactPage" | "CollectionPage";
  showHeaderLogos?: boolean;
  /** Set to a public path to replace the Cambridge logo placeholder on the homepage. */
  cambridgeLogoSrc?: string;
  /** Set to a public path to replace the school logo placeholder on the homepage. */
  schoolLogoSrc?: string;
}

const {
  title,
  description,
  pageType = "WebPage",
  showHeaderLogos = false,
  cambridgeLogoSrc = "/images/Cambridge%20logo.png",
  schoolLogoSrc = "/images/School%20logo.png"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, schoolUrl).href;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: schoolName,
  alternateName: schoolShortName,
  description:
    "International school in Trichy offering Cambridge CIE curriculum, iPlay, iDiscover, iLead, and Individual Learning Plans.",
  url: `${schoolUrl}/`,
  logo: `${schoolUrl}/assets/logo/wwis-logo.png`,
  telephone: contactInfo.phone,
  email: contactInfo.email,
  openingHours: contactInfo.hoursMachine,
  address: {
    "@type": "PostalAddress",
    streetAddress: "11th Sector, 18th Cross, Morais City, Near Airport",
    addressLocality: contactInfo.locality,
    addressRegion: contactInfo.region,
    postalCode: contactInfo.postalCode,
    addressCountry: contactInfo.country
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: contactInfo.phoneHref,
    email: contactInfo.email,
    contactType: "admissions",
    areaServed: "IN",
    availableLanguage: ["English", "Tamil", "Hindi"]
  },
  knowsAbout: ["Cambridge CIE", "iPlay", "iDiscover", "iLead", "Individual Learning Plans"]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: `${schoolName} (${schoolShortName})`,
  url: `${schoolUrl}/`,
  potentialAction: {
    "@type": "SearchAction",
    target: `${schoolUrl}/our-programs?query={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": pageType,
  name: title,
  description,
  url: canonical
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${schoolUrl}/`
    },
    ...(Astro.url.pathname !== "/"
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: title.split("|")[0].trim(),
            item: canonical
          }
        ]
      : [])
  ]
};

const navItems = [
  ["Home", "/"],
  ["About Us", "/about"],
  ["Our Programs", "/our-programs"],
  ["Blog", "/blog"],
  ["Our Team", "/our-team"],
  ["Careers", "/careers"],
  ["Find Us", "/find-us"]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content={brand.colors.navy} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" id="site-header">
      <div class="topbar">
        <span>{contactInfo.hours}</span>
        <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a>
        <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
      </div>
      <nav class="nav" aria-label="Main navigation">
        {showHeaderLogos && (
          <div class="header-logo header-logo--cambridge">
            {cambridgeLogoSrc ? (
              <img src={cambridgeLogoSrc} alt="Cambridge International" class="header-logo__img" />
            ) : (
              <span class="header-logo__placeholder">[CAMBRIDGE LOGO]</span>
            )}
          </div>
        )}
        <div class="nav-main">
          <a class="brand-mark" href="/" aria-label="Wisdom Wealth International School home">
            <span class="brand-symbol">WW</span>
            <span>
              <strong>{schoolShortName}</strong>
              <small>Wisdom Wealth International School</small>
            </span>
          </a>
          <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav-menu">Menu</button>
          <div class="nav-menu" id="nav-menu">
            {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
        </div>
        {showHeaderLogos && (
          <div class="header-logo header-logo--school">
            {schoolLogoSrc ? (
              <img src={schoolLogoSrc} alt="Wisdom Wealth International School" class="header-logo__img" />
            ) : (
              <span class="header-logo__placeholder">[SCHOOL LOGO]</span>
            )}
          </div>
        )}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <p class="footer-brand">{schoolName}</p>
        <p class="footer-promise">{brand.promise}</p>
      </div>
      <address>
        <strong>Admissions</strong>
        <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a>
        <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
        <span>{contactInfo.address}</span>
      </address>
      <div>
        <strong>Explore</strong>
        <a href="/our-programs">Our Programs</a>
        <a href="/find-us">Find Us</a>
        <a href="/blog">Blog</a>
        <a href="/careers">Careers</a>
      </div>
    </footer>
    <Chatbot />
    <script>
      /* ── Sticky header shadow on scroll ── */
      const header = document.getElementById("site-header");
      const onScroll = () => {
        header?.classList.toggle("is-scrolled", window.scrollY > 10);
      };
      window.addEventListener("scroll", onScroll, { passive: true });

      /* ── Mobile nav toggle ── */
      const navToggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
      const navMenu = document.querySelector<HTMLElement>(".nav-menu");
      navToggle?.addEventListener("click", () => {
        const expanded = navToggle.getAttribute("aria-expanded") === "true";
        navToggle.setAttribute("aria-expanded", String(!expanded));
        navMenu?.classList.toggle("is-open", !expanded);
      });

      /* ── Fade-up scroll animation ── */
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".fade-up").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════
     DESIGN TOKENS - PREMIUM ACADEMIC THEME
  ═══════════════════════════════════════════ */
  :root {
    /* Primary Colors */
    --peacock:      #0F6F67;
    --peacock-dark: #0B5D56;
    --peacock-light: #1A8F85;

    /* Backgrounds */
    --ivory-bg:     #F4EFE5;
    --ivory-surface:#FCFAF4;
    --white-pure:   #FFFFFF;

    /* Accent */
    --gold-soft:    #D9B85F;
    --gold-muted:   #C9A54B;
    --gold-dark:    #B8943A;

    /* Text */
    --text-primary: #23312D;
    --text-secondary:#5E6763;
    --text-muted:   #8A928E;

    /* Borders */
    --border-ivory: #D8D0C1;
    --border-light: #E7E0D2;

    /* Utilities */
    --shadow-sm:    0 4px 12px rgba(15, 111, 103, 0.08);
    --shadow-md:    0 8px 24px rgba(15, 111, 103, 0.12);
    --shadow-lg:    0 16px 48px rgba(15, 111, 103, 0.15);

    /* Legacy aliases (for compatibility) */
    --emerald:      var(--peacock);
    --forest:       var(--peacock-dark);
    --sage:         var(--peacock-light);
    --ivory:        var(--ivory-bg);
    --ivory-2:      var(--ivory-surface);
    --ivory-3:      var(--border-light);
    --white:        var(--white-pure);
    --charcoal:     var(--text-primary);
    --charcoal-2:   var(--text-secondary);
    --muted:        var(--text-muted);
    --gold:         var(--gold-soft);
    --gold-light:   var(--gold-muted);
    --gold-dark:    var(--gold-dark);
    --gold-text:    #996633;
    --line:         rgba(15, 75, 70, 0.12);
    --line-gold:    rgba(201, 162, 39, 0.28);

    /* Typography */
    --font-display: "Poppins", "Inter", sans-serif;
    --font-body:    "Inter", "Trebuchet MS", sans-serif;

    /* Layout */
    --radius-sm:    10px;
    --radius-md:    16px;
    --radius-lg:    20px;
    --radius-pill:  999px;
    --max-width:    1180px;
    --section-pad:  72px max(22px, calc((100vw - var(--max-width)) / 2));
  }

  /* ═══════════════════════════════════════════
     RESET & BASE
  ═══════════════════════════════════════════ */
  * {
    box-sizing: border-box;
  }

  html {
    color: var(--charcoal);
    font-family: var(--font-body);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background: var(--ivory-bg);
    line-height: 1.65;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  section {
    padding: var(--section-pad);
    background: var(--ivory-bg);
    position: relative;
    overflow: hidden;
  }

  section::after {
    content: "";
    position: absolute;
    inset: auto max(22px, calc((100vw - var(--max-width)) / 2)) 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(216, 208, 193, 0.7), transparent);
    pointer-events: none;
  }

  main > section:not(.band):not(.soft-band):not(.band-gradient):nth-of-type(odd) {
    background: var(--white-pure);
  }

  main > section:not(.band):not(.soft-band):not(.band-gradient):nth-of-type(even) {
    background: var(--ivory-surface);
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    line-height: 1.1;
    margin: 0;
    color: var(--peacock);
    letter-spacing: -0.01em;
    font-weight: 600;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    font-weight: 700;
  }

  h2 {
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    font-weight: 600;
  }

  h3 {
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 600;
  }

  p {
    margin: 0;
    color: var(--charcoal-2);
    line-height: 1.7;
  }

  section {
    padding: var(--section-pad);
  }

  /* ═══════════════════════════════════════════
     SKIP LINK
  ═══════════════════════════════════════════ */
  .skip-link {
    background: var(--gold);
    color: var(--emerald);
    font-weight: 700;
    left: 16px;
    padding: 10px 14px;
    position: fixed;
    top: -100px;
    z-index: 50;
    border-radius: var(--radius-sm);
  }

  .skip-link:focus {
    top: 16px;
  }

  /* ═══════════════════════════════════════════
     HEADER & NAV
  ═══════════════════════════════════════════ */
  .site-header {
    background: linear-gradient(135deg, var(--peacock) 0%, var(--peacock-dark) 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(16px);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    box-shadow: 0 12px 34px rgba(15, 59, 58, 0.16);
  }

  .site-header.is-scrolled {
    box-shadow: 0 4px 24px rgba(15, 111, 103, 0.15);
  }

  .topbar {
    align-items: center;
    background: rgba(14, 59, 58, 0.94);
    color: rgba(255, 255, 255, 0.92);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.82rem;
    font-weight: 400;
    gap: 20px;
    justify-content: center;
    padding: 7px 18px;
    letter-spacing: 0.01em;
  }

  .topbar a {
    color: var(--gold-soft);
    text-decoration: none;
    transition: color 0.2s;
  }

  .topbar a:hover {
    color: var(--white-pure);
  }

  .nav {
    align-items: center;
    display: flex;
    gap: 20px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1260px;
    padding: 14px 24px;
    position: relative;
  }

  .nav-main {
    align-items: center;
    display: flex;
    flex: 1;
    gap: 20px;
    justify-content: space-between;
    min-width: 0;
  }

  .header-logo {
    align-items: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1.5px solid rgba(217, 184, 95, 0.3);
    border-radius: var(--radius-sm);
    color: var(--gold-soft);
    display: flex;
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 700;
    height: 52px;
    justify-content: center;
    letter-spacing: 0.03em;
    line-height: 1.2;
    max-width: 132px;
    overflow: hidden;
    padding: 0 8px;
    text-align: center;
    width: 120px;
  }

  .header-logo__img {
    display: block;
    height: 100%;
    object-fit: contain;
    padding: 6px;
    width: 100%;
  }

  .header-logo__placeholder {
    padding: 0 4px;
  }

  .brand-mark {
    align-items: center;
    display: inline-flex;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-symbol {
    align-items: center;
    background: rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-sm);
    color: var(--white-pure);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    height: 48px;
    justify-content: center;
    letter-spacing: 0.05em;
    width: 48px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    flex-shrink: 0;
  }

  .brand-mark strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--white-pure);
    letter-spacing: 0.02em;
  }

  .brand-mark small {
    display: block;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 400;
    letter-spacing: 0.01em;
    margin-top: 1px;
  }

  .nav-menu {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    justify-content: flex-end;
  }

  .nav-menu a {
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    font-weight: 500;
    padding: 8px 12px;
    text-decoration: none;
    color: var(--white-pure);
    position: relative;
    transition: color 0.2s ease;
    letter-spacing: 0.01em;
  }

  .nav-menu a::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--gold-soft);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.28s ease;
    border-radius: 2px;
  }

  .nav-menu a:hover {
    color: var(--gold-soft);
  }

  .nav-menu a:hover::after,
  .nav-menu a:focus::after {
    transform: scaleX(1);
  }

  .nav-toggle {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
    color: var(--white-pure);
    cursor: pointer;
    display: none;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    padding: 10px 16px;
    transition: background 0.2s;
  }

  .nav-toggle:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  /* ═══════════════════════════════════════════
     PAGE HERO (default inner pages)
  ═══════════════════════════════════════════ */
  .page-hero {
    background: var(--peacock);
    color: var(--white-pure);
    min-height: 52vh;
    overflow: hidden;
    position: relative;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(217, 184, 95, 0.1) 0%, transparent 55%),
      radial-gradient(ellipse at 10% 90%, rgba(11, 93, 86, 0.3) 0%, transparent 50%);
    pointer-events: none;
  }

  .page-hero::after {
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    content: "";
    inset: 0;
    position: absolute;
    opacity: 0.5;
    pointer-events: none;
  }

  .page-hero__content {
    max-width: 860px;
    position: relative;
    z-index: 1;
  }

  .page-hero--centered {
    align-items: center;
    display: flex;
    justify-content: center;
    text-align: center;
  }

  .page-hero--centered .page-hero__content {
    margin: 0 auto;
  }

  .page-hero--centered p {
    margin-left: auto;
    margin-right: auto;
  }

  .page-hero--centered .hero-actions {
    justify-content: center;
  }

  .page-hero p {
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin-top: 20px;
    max-width: 680px;
    color: rgba(255, 255, 255, 0.88);
    font-weight: 300;
    line-height: 1.7;
  }

  /* Gold accent line at bottom of hero */
  .page-hero .gold-accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--gold-soft) 30%, var(--gold-muted) 50%, var(--gold-soft) 70%, transparent);
    opacity: 0.8;
  }

  /* ═══════════════════════════════════════════
     EYEBROW & SECTION HEADER
  ═══════════════════════════════════════════ */
  .eyebrow {
    align-items: center;
    color: #B8943A;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: "";
    display: block;
    width: 28px;
    height: 2px;
    background: var(--gold-soft);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .page-hero .eyebrow {
    color: var(--gold-soft);
  }

  .page-hero .eyebrow::before {
    background: var(--gold-muted);
  }

  .hero-actions,
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }

  .section-header {
    max-width: 780px;
    margin-bottom: 40px;
  }

  .section-header p:not(.eyebrow) {
    font-size: 1.08rem;
    margin-top: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ═══════════════════════════════════════════
     BUTTONS
  ═══════════════════════════════════════════ */
  .button {
    border: 2px solid transparent;
    border-radius: var(--radius-pill);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    justify-content: center;
    letter-spacing: 0.03em;
    min-width: 160px;
    padding: 13px 28px;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    background: var(--gold-soft);
    border-color: var(--gold-soft);
    color: var(--peacock-dark);
    box-shadow: 0 8px 24px rgba(201, 162, 39, 0.24);
  }

  .button-primary:hover {
    background: var(--gold-muted);
    border-color: var(--gold-muted);
    box-shadow: 0 10px 30px rgba(201, 162, 39, 0.28);
  }

  .button-secondary {
    background: transparent;
    border-color: var(--gold-soft);
    color: var(--peacock-dark);
  }

  .button-secondary:hover {
    background: var(--gold-soft);
    color: var(--peacock-dark);
  }

  .button--primary {
    background: var(--gold-soft) !important;
    border-color: var(--gold-soft) !important;
    color: var(--peacock-dark) !important;
    box-shadow: 0 8px 24px rgba(201, 162, 39, 0.24) !important;
  }

  .button--primary:hover {
    background: var(--gold-muted) !important;
    border-color: var(--gold-muted) !important;
  }

  .button--secondary {
    background: transparent !important;
    border-color: var(--gold-soft) !important;
    color: var(--peacock-dark) !important;
  }

  .button--secondary:hover {
    background: var(--gold-soft) !important;
    color: var(--peacock-dark) !important;
  }

  .button-light {
    background: var(--white-pure);
    border-color: var(--border-ivory);
    color: var(--peacock);
    box-shadow: var(--shadow-sm);
  }

  .button-light:hover {
    border-color: var(--gold-soft);
    background: var(--ivory-surface);
    box-shadow: var(--shadow-md);
  }

