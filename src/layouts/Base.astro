---
import Chatbot from "../components/Chatbot.astro";
import { brand, contactInfo, schoolName, schoolShortName, schoolUrl } from "../data/school";

interface Props {
  title: string;
  description: string;
  pageType?: "WebPage" | "AboutPage" | "ContactPage" | "CollectionPage";
}

const { title, description, pageType = "WebPage" } = Astro.props;
const canonical = new URL(Astro.url.pathname, schoolUrl).href;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: schoolName,
  alternateName: schoolShortName,
  description:
    "International school in Trichy offering Cambridge CIE curriculum, iPlay, iDiscover, iLead, and Individual Learning Plans.",
  url: `${schoolUrl}/`,
  logo: `${schoolUrl}/assets/logo/wwis-logo.png`,
  telephone: contactInfo.phone,
  email: contactInfo.email,
  openingHours: contactInfo.hoursMachine,
  address: {
    "@type": "PostalAddress",
    streetAddress: "11th Sector, 18th Cross, Morais City, Near Airport",
    addressLocality: contactInfo.locality,
    addressRegion: contactInfo.region,
    postalCode: contactInfo.postalCode,
    addressCountry: contactInfo.country
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: contactInfo.phoneHref,
    email: contactInfo.email,
    contactType: "admissions",
    areaServed: "IN",
    availableLanguage: ["English", "Tamil", "Hindi"]
  },
  knowsAbout: ["Cambridge CIE", "iPlay", "iDiscover", "iLead", "Individual Learning Plans"]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: `${schoolName} (${schoolShortName})`,
  url: `${schoolUrl}/`,
  potentialAction: {
    "@type": "SearchAction",
    target: `${schoolUrl}/services?query={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": pageType,
  name: title,
  description,
  url: canonical
};

const navItems = [
  ["Home", "/"],
  ["About", "/about"],
  ["Programs", "/services"],
  ["Admissions", "/admissions"],
  ["Facilities", "/facilities"],
  ["Sports & Clubs", "/sports-clubs"],
  ["Resources", "/parent-resources"],
  ["Gallery", "/gallery"],
  ["Contact", "/contact"]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content={brand.colors.navy} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="topbar">
        <span>{contactInfo.hours}</span>
        <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a>
        <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
      </div>
      <nav class="nav" aria-label="Main navigation">
        <a class="brand-mark" href="/" aria-label="Wisdom Wealth International School home">
          <span class="brand-symbol">WW</span>
          <span>
            <strong>{schoolShortName}</strong>
            <small>Wisdom Wealth International School</small>
          </span>
        </a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav-menu">Menu</button>
        <div class="nav-menu" id="nav-menu">
          {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <p class="footer-brand">{schoolName}</p>
        <p>{brand.promise}</p>
      </div>
      <address>
        <strong>Admissions</strong>
        <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a>
        <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
        <span>{contactInfo.address}</span>
      </address>
      <div>
        <strong>Explore</strong>
        <a href="/admissions">Admissions</a>
        <a href="/services">Programs</a>
        <a href="/parent-resources">Parent Resources</a>
      </div>
    </footer>
    <Chatbot />
    <script>
      const navToggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
      const navMenu = document.querySelector<HTMLElement>(".nav-menu");
      navToggle?.addEventListener("click", () => {
        const expanded = navToggle.getAttribute("aria-expanded") === "true";
        navToggle.setAttribute("aria-expanded", String(!expanded));
        navMenu?.classList.toggle("is-open", !expanded);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --ink: #10243f;
    --navy: #133b5c;
    --teal: #007b7a;
    --gold: #d79b2b;
    --coral: #d85f45;
    --mist: #eef7f6;
    --paper: #fffaf1;
    --white: #ffffff;
    --line: rgba(16, 36, 63, 0.14);
    --shadow: 0 22px 70px rgba(16, 36, 63, 0.14);
    --font-display: Georgia, "Times New Roman", serif;
    --font-body: "Trebuchet MS", Verdana, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--ink);
    font-family: var(--font-body);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      linear-gradient(135deg, rgba(238, 247, 246, 0.88), rgba(255, 250, 241, 0.92)),
      radial-gradient(circle at top left, rgba(215, 155, 43, 0.16), transparent 32%),
      var(--white);
    line-height: 1.6;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    line-height: 1.08;
    margin: 0;
  }

  h1 {
    font-size: clamp(2.55rem, 7vw, 5.5rem);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  h3 {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
  }

  p {
    margin: 0;
  }

  section {
    padding: 72px max(22px, calc((100vw - 1180px) / 2));
  }

  .skip-link {
    background: var(--gold);
    color: var(--ink);
    left: 16px;
    padding: 10px 14px;
    position: fixed;
    top: -100px;
    z-index: 50;
  }

  .skip-link:focus {
    top: 16px;
  }

  .site-header {
    background: rgba(255, 255, 255, 0.9);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
  }

  .topbar {
    align-items: center;
    background: var(--ink);
    color: var(--white);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.88rem;
    gap: 14px;
    justify-content: center;
    padding: 8px 18px;
  }

  .nav {
    align-items: center;
    display: flex;
    gap: 20px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1220px;
    padding: 14px 22px;
  }

  .brand-mark {
    align-items: center;
    display: inline-flex;
    gap: 12px;
    text-decoration: none;
  }

  .brand-symbol {
    align-items: center;
    background: linear-gradient(135deg, var(--navy), var(--teal));
    color: var(--white);
    display: inline-flex;
    font-family: var(--font-display);
    font-weight: 700;
    height: 48px;
    justify-content: center;
    width: 48px;
  }

  .brand-mark small {
    display: block;
    font-size: 0.78rem;
  }

  .nav-menu {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: flex-end;
  }

  .nav-menu a {
    border-radius: 6px;
    font-size: 0.94rem;
    padding: 8px 10px;
    text-decoration: none;
  }

  .nav-menu a:hover,
  .nav-menu a:focus {
    background: var(--mist);
  }

  .nav-toggle {
    background: var(--navy);
    border: 0;
    color: var(--white);
    display: none;
    padding: 10px 14px;
  }

  .page-hero {
    background:
      linear-gradient(120deg, rgba(16, 36, 63, 0.9), rgba(0, 123, 122, 0.8)),
      linear-gradient(45deg, rgba(215, 155, 43, 0.24), transparent);
    color: var(--white);
    min-height: 70vh;
    overflow: hidden;
    position: relative;
  }

  .page-hero::after {
    background-image:
      linear-gradient(90deg, rgba(255, 255, 255, 0.09) 1px, transparent 1px),
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 44px 44px;
    content: "";
    inset: 0;
    opacity: 0.55;
    position: absolute;
  }

  .page-hero__content {
    max-width: 900px;
    position: relative;
    z-index: 1;
  }

  .page-hero p {
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    margin-top: 22px;
    max-width: 760px;
  }

  .eyebrow {
    color: var(--gold);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .hero-actions,
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .button {
    border: 1px solid transparent;
    border-radius: 6px;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    min-width: 160px;
    padding: 13px 18px;
    text-decoration: none;
  }

  .button-primary {
    background: var(--gold);
    color: var(--ink);
  }

  .button-secondary {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.5);
    color: inherit;
  }

  .button-light {
    background: var(--white);
    border-color: var(--line);
    color: var(--ink);
  }

  .section-header {
    max-width: 780px;
    margin-bottom: 34px;
  }

  .section-header p:not(.eyebrow) {
    font-size: 1.08rem;
    margin-top: 14px;
  }

  .grid {
    display: grid;
    gap: 18px;
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 10px 34px rgba(16, 36, 63, 0.07);
    padding: 24px;
  }

  .band {
    background: var(--ink);
    color: var(--white);
  }

  .soft-band {
    background: rgba(238, 247, 246, 0.72);
  }

  .numbered-list {
    counter-reset: steps;
    display: grid;
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .numbered-list li {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    counter-increment: steps;
    padding: 18px 18px 18px 58px;
    position: relative;
  }

  .numbered-list li::before {
    background: var(--teal);
    color: var(--white);
    content: counter(steps);
    font-weight: 700;
    height: 30px;
    left: 18px;
    line-height: 30px;
    position: absolute;
    text-align: center;
    top: 18px;
    width: 30px;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
  }

  .tag-list li {
    background: var(--mist);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 12px;
  }

  .form-panel {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    padding: 28px;
  }

  label {
    display: block;
    font-weight: 700;
    margin-bottom: 6px;
  }

  input,
  select,
  textarea {
    border: 1px solid var(--line);
    border-radius: 6px;
    font: inherit;
    padding: 12px;
    width: 100%;
  }

  textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .full {
    grid-column: 1 / -1;
  }

  .site-footer {
    background: var(--navy);
    color: var(--white);
    display: grid;
    gap: 28px;
    grid-template-columns: 2fr 1.4fr 1fr;
    padding: 48px max(22px, calc((100vw - 1180px) / 2));
  }

  .site-footer a,
  .site-footer span {
    display: block;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 10px;
  }

  .chatbot {
    bottom: 18px;
    position: fixed;
    right: 18px;
    z-index: 30;
  }

  .chatbot-toggle {
    background: var(--coral);
    border: 0;
    border-radius: 999px;
    box-shadow: var(--shadow);
    color: var(--white);
    font-weight: 800;
    padding: 14px 18px;
  }

  .chatbot-panel {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    bottom: 58px;
    box-shadow: var(--shadow);
    max-height: min(660px, calc(100vh - 100px));
    overflow: auto;
    padding: 18px;
    position: absolute;
    right: 0;
    width: min(380px, calc(100vw - 36px));
  }

  .chatbot-panel header {
    padding-right: 32px;
    position: relative;
  }

  .chatbot-panel h2 {
    font-size: 1.5rem;
  }

  .chatbot-close {
    background: var(--ink);
    border: 0;
    color: var(--white);
    height: 28px;
    position: absolute;
    right: 0;
    top: 0;
    width: 28px;
  }

  .chatbot-messages {
    display: grid;
    gap: 10px;
    margin: 16px 0;
    max-height: 220px;
    overflow: auto;
  }

  .bot-message,
  .user-message {
    border-radius: 8px;
    padding: 10px 12px;
  }

  .bot-message {
    background: var(--mist);
  }

  .user-message {
    background: var(--ink);
    color: var(--white);
    margin-left: 28px;
  }

  .chatbot-prompts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chatbot-prompts button {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 10px;
  }

  .chatbot-form {
    margin-top: 16px;
  }

  .chatbot-form div {
    display: flex;
    gap: 8px;
  }

  .chatbot-form button {
    background: var(--teal);
    border: 0;
    color: var(--white);
    padding: 0 14px;
  }

  .chatbot-escalation {
    font-size: 0.88rem;
    margin-top: 12px;
  }

  @media (max-width: 900px) {
    section {
      padding: 54px 20px;
    }

    .nav {
      align-items: flex-start;
    }

    .nav-toggle {
      display: inline-flex;
    }

    .nav-menu {
      background: var(--white);
      border-top: 1px solid var(--line);
      display: none;
      flex-direction: column;
      left: 0;
      padding: 16px 20px 20px;
      position: absolute;
      right: 0;
      top: 100%;
    }

    .nav-menu.is-open {
      display: flex;
    }

    .nav-menu a {
      width: 100%;
    }

    .grid-2,
    .grid-3,
    .form-grid,
    .site-footer {
      grid-template-columns: 1fr;
    }

    .page-hero {
      min-height: 62vh;
    }
  }

  @media (max-width: 560px) {
    .topbar {
      align-items: flex-start;
      flex-direction: column;
    }

    .brand-mark small {
      max-width: 190px;
    }

    .chatbot {
      bottom: 12px;
      right: 12px;
    }
  }
</style>
