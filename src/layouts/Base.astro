---
import Chatbot from "../components/Chatbot.astro";
import { brand, contactInfo, schoolName, schoolShortName, schoolUrl } from "../data/school";

interface Props {
  title: string;
  description: string;
  pageType?: "WebPage" | "AboutPage" | "ContactPage" | "CollectionPage";
  showHeaderLogos?: boolean;
  /** Set to a public path to replace the Cambridge logo placeholder on the homepage. */
  cambridgeLogoSrc?: string;
  /** Set to a public path to replace the school logo placeholder on the homepage. */
  schoolLogoSrc?: string;
}

const {
  title,
  description,
  pageType = "WebPage",
  showHeaderLogos = false,
  cambridgeLogoSrc = "/images/Cambridge%20logo.png",
  schoolLogoSrc = "/images/School%20logo.png"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, schoolUrl).href;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: schoolName,
  alternateName: schoolShortName,
  description:
    "International school in Trichy offering Cambridge CIE curriculum, iPlay, iDiscover, iLead, and Individual Learning Plans.",
  url: `${schoolUrl}/`,
  logo: `${schoolUrl}/assets/logo/wwis-logo.png`,
  telephone: contactInfo.phone,
  email: contactInfo.email,
  openingHours: contactInfo.hoursMachine,
  address: {
    "@type": "PostalAddress",
    streetAddress: "11th Sector, 18th Cross, Morais City, Near Airport",
    addressLocality: contactInfo.locality,
    addressRegion: contactInfo.region,
    postalCode: contactInfo.postalCode,
    addressCountry: contactInfo.country
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: contactInfo.phoneHref,
    email: contactInfo.email,
    contactType: "admissions",
    areaServed: "IN",
    availableLanguage: ["English", "Tamil", "Hindi"]
  },
  knowsAbout: ["Cambridge CIE", "iPlay", "iDiscover", "iLead", "Individual Learning Plans"]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: `${schoolName} (${schoolShortName})`,
  url: `${schoolUrl}/`,
  potentialAction: {
    "@type": "SearchAction",
    target: `${schoolUrl}/our-programs?query={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": pageType,
  name: title,
  description,
  url: canonical
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `${schoolUrl}/`
    },
    ...(Astro.url.pathname !== "/"
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: title.split("|")[0].trim(),
            item: canonical
          }
        ]
      : [])
  ]
};

const navItems = [
  ["Home", "/"],
  ["About Us", "/about"],
  ["Our Programs", "/our-programs"],
  ["Blog", "/blog"],
  ["Our Team", "/our-team"],
  ["Careers", "/careers"],
  ["Find Us", "/find-us"]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content={brand.colors.navy} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" id="site-header">
      <div class="topbar">
        <span>{contactInfo.hours}</span>
        <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a>
        <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
      </div>
      <nav class="nav" aria-label="Main navigation">
        {showHeaderLogos && (
          <div class="header-logo header-logo--cambridge">
            {cambridgeLogoSrc ? (
              <img src={cambridgeLogoSrc} alt="Cambridge International" class="header-logo__img" />
            ) : (
              <span class="header-logo__placeholder">[CAMBRIDGE LOGO]</span>
            )}
          </div>
        )}
        <div class="nav-main">
          <a class="brand-mark" href="/" aria-label="Wisdom Wealth International School home">
            <span class="brand-symbol">WW</span>
            <span>
              <strong>{schoolShortName}</strong>
              <small>Wisdom Wealth International School</small>
            </span>
          </a>
          <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav-menu">Menu</button>
          <div class="nav-menu" id="nav-menu">
            {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
          <div class="nav-cta">
            <a class="btn-book" href="/find-us">Book a Campus Visit</a>
          </div>
        </div>
        {showHeaderLogos && (
          <div class="header-logo header-logo--school">
            {schoolLogoSrc ? (
              <img src={schoolLogoSrc} alt="Wisdom Wealth International School" class="header-logo__img" />
            ) : (
              <span class="header-logo__placeholder">[SCHOOL LOGO]</span>
            )}
          </div>
        )}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-brand">
          <p class="footer-school-name">{schoolName}</p>
          <p class="footer-promise">{brand.promise}</p>
        </div>
        <address class="footer-contact">
          <strong>Admissions</strong>
          <a href={`tel:${contactInfo.phoneHref}`}>{contactInfo.phone}</a>
          <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
          <span>{contactInfo.address}</span>
        </address>
        <div class="footer-links">
          <strong>Explore</strong>
          <a href="/our-programs">Our Programs</a>
          <a href="/find-us">Find Us</a>
          <a href="/blog">Blog</a>
          <a href="/careers">Careers</a>
        </div>
      </div>
    </footer>
    <Chatbot />
    <script>
      /* ── Sticky header shadow on scroll ── */
      const header = document.getElementById("site-header");
      const onScroll = () => {
        header?.classList.toggle("is-scrolled", window.scrollY > 10);
      };
      window.addEventListener("scroll", onScroll, { passive: true });

      /* ── Mobile nav toggle ── */
      const navToggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
      const navMenu = document.querySelector<HTMLElement>(".nav-menu");
      navToggle?.addEventListener("click", () => {
        const expanded = navToggle.getAttribute("aria-expanded") === "true";
        navToggle.setAttribute("aria-expanded", String(!expanded));
        navMenu?.classList.toggle("is-open", !expanded);
      });

      /* ── Fade-up scroll animation ── */
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".fade-up").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════
     DESIGN TOKENS - WWIS PREMIUM THEME
  ═══════════════════════════════════════════ */
  :root {
     /* Primary Colors - Deep Royal Blue & Navy (brand-forward)
        - royal: vivid primary for CTAs and large accents
        - navy: deep base for headings, footer, and text contrasts */
     --royal-blue:    #0B3B7A; /* deep royal blue */
     --navy-blue:     #06223A; /* near-black navy */

     /* Accent Colors - soft pinks used sparingly for highlights and CTAs */
     --light-pink:    #FDE6EA;
     --soft-rose:     #F7C7D0;
     --pink-accent-1: #FF7EB6; /* primary pink accent */
     --pink-accent-2: #FF73A9; /* stronger pink for gradients */
     --pink-gradient: linear-gradient(135deg, #FF7EB6 0%, #7AB8FF 100%);

     /* Supporting neutrals */
     --soft-white:    #FFFFFF;
     --cream-very-light: #FFF8F6;
     --light-blue-bg:  #F3F9FF;
     --light-grey:     #F5F6F8;

     /* Text Colors */
     --text-primary:  #042034; /* dark navy for headings/text */
     --text-secondary:#3F5566; /* softened body text */
     --text-muted:    #7B8892;

     /* Borders */
     --border-soft:   rgba(4, 32, 52, 0.06);
     --border-pink:   rgba(255, 126, 182, 0.12);

     /* Shadows - subtle and elegant */
     --shadow-sm:     0 6px 18px rgba(4, 32, 52, 0.06);
     --shadow-md:     0 12px 30px rgba(4, 32, 52, 0.08);
     --shadow-lg:     0 28px 70px rgba(4, 32, 52, 0.10);
     --shadow-glass:  0 8px 40px rgba(9, 30, 45, 0.06);

     /* Decorative gradient blob for cards/hero accents */
     --rose-soft-gradient: linear-gradient(120deg, rgba(255,126,182,0.12) 0%, rgba(122,184,255,0.06) 100%);

     /* Token aliases for clarity */
     --white-pure:    var(--soft-white);
     --ivory-bg:      var(--cream-very-light);
     --accent-pink:   var(--pink-accent-1);
     --accent-pink-2: var(--pink-accent-2);
     --accent-gradient: var(--pink-gradient);

     /* Typography */
     --font-display:  "Poppins", "Plus Jakarta Sans", "Manrope", sans-serif;
     --font-body:     "Plus Jakarta Sans", "Inter", "Segoe UI", sans-serif;

     /* Layout */
     --radius-sm:     10px;
     --radius-md:     14px;
     --radius-lg:     20px;
     --radius-pill:   999px;
     --max-width:     1240px;
     --section-pad:   72px max(22px, calc((100vw - var(--max-width)) / 2));
  }

  /* ═══════════════════════════════════════════
     RESET & BASE
  ═══════════════════════════════════════════ */
  * {
    box-sizing: border-box;
  }

  html {
    color: var(--charcoal);
    font-family: var(--font-body);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background: var(--ivory-bg);
    line-height: 1.65;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  section {
    padding: var(--section-pad);
    background: var(--ivory-bg);
    position: relative;
    overflow: hidden;
  }

  section::after {
    content: "";
    position: absolute;
    inset: auto max(22px, calc((100vw - var(--max-width)) / 2)) 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(216, 208, 193, 0.7), transparent);
    pointer-events: none;
  }

  main > section:not(.band):not(.soft-band):not(.band-gradient):nth-of-type(odd) {
    background: var(--white-pure);
  }

  main > section:not(.band):not(.soft-band):not(.band-gradient):nth-of-type(even) {
    background: var(--ivory-surface);
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    line-height: 1.1;
    margin: 0;
    color: var(--navy-blue);
    letter-spacing: -0.01em;
    font-weight: 600;
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    font-weight: 700;
  }

  h2 {
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    font-weight: 600;
  }

  h3 {
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 600;
  }

  p {
    margin: 0;
    color: var(--charcoal-2);
    line-height: 1.7;
  }

  section {
    padding: var(--section-pad);
  }

  /* ═══════════════════════════════════════════
     SKIP LINK
  ═══════════════════════════════════════════ */
  .skip-link {
    background: var(--gold-accent);
    color: var(--navy-blue);
    font-weight: 700;
    left: 16px;
    padding: 10px 14px;
    position: fixed;
    top: -100px;
    z-index: 50;
    border-radius: var(--radius-sm);
  }

  .skip-link:focus {
    top: 16px;
  }

  /* ═══════════════════════════════════════════
     HEADER & NAVIGATION - PREMIUM GLASSMORPHISM
  ═══════════════════════════════════════════ */
  .site-header {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(18, 61, 109, 0.08);
    position: sticky;
    top: 0;
    z-index: 20;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    box-shadow: 0 4px 24px rgba(11, 61, 46, 0.08);
  }

  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(11, 61, 46, 0.12);
  }

  .topbar {
    align-items: center;
    background: linear-gradient(90deg, rgba(6, 34, 58, 0.98) 0%, rgba(11, 59, 110, 0.95) 100%);
    color: rgba(255, 255, 255, 0.96);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.82rem;
    font-weight: 500;
    gap: 12px;
    justify-content: center;
    padding: 8px 18px;
    letter-spacing: 0.01em;
  }

  .topbar a {
    color: rgba(255,255,255,0.92);
    text-decoration: none;
    transition: color 0.2s, opacity 0.2s;
  }

  .topbar a:hover {
    color: var(--light-pink);
  }

  .nav {
    align-items: center;
    display: flex;
    gap: 20px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1260px;
    padding: 14px 24px;
    position: relative;
  }

  .nav-main {
    align-items: center;
    display: flex;
    flex: 1;
    gap: 20px;
    justify-content: space-between;
    min-width: 0;
  }

  .header-logo {
    align-items: center;
    background: rgba(255,255,255,0.04);
    border: 1.25px solid rgba(10, 36, 70, 0.06);
    border-radius: var(--radius-sm);
    color: var(--accent-pink);
    display: flex;
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 700;
    height: 56px;
    justify-content: center;
    letter-spacing: 0.02em;
    line-height: 1.2;
    max-width: 140px;
    overflow: hidden;
    padding: 0 8px;
    text-align: center;
    width: 140px;
  }

  .header-logo__img {
    display: block;
    height: 100%;
    object-fit: contain;
    padding: 6px;
    width: 100%;
  }

  .header-logo__placeholder {
    padding: 0 6px;
  }

  .brand-mark {
    align-items: center;
    display: inline-flex;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-symbol {
    align-items: center;
    background: linear-gradient(135deg, var(--accent-pink) 0%, var(--royal-blue) 100%);
    border-radius: 12px;
    color: var(--white-pure);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    height: 52px;
    justify-content: center;
    letter-spacing: 0.04em;
    width: 52px;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  .brand-mark strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy-blue);
    letter-spacing: 0.02em;
  }

  .brand-mark small {
    display: block;
    font-size: 0.72rem;
    color: rgba(11, 61, 46, 0.75);
    font-weight: 400;
    letter-spacing: 0.01em;
    margin-top: 1px;
  }

  .nav-menu {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    justify-content: flex-end;
  }

  .nav-menu a {
    border-radius: var(--radius-sm);
    font-size: 0.92rem;
    font-weight: 600;
    padding: 8px 12px;
    text-decoration: none;
    color: var(--text-primary);
    position: relative;
    transition: color 0.22s ease, transform 0.22s ease;
    letter-spacing: 0.01em;
  }

  .nav-menu a::after {
    content: "";
    position: absolute;
    bottom: 6px;
    left: 12px;
    right: 12px;
    height: 3px;
    background: linear-gradient(90deg, var(--pink-accent-1), var(--royal-blue));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.28s ease;
    border-radius: 4px;
    opacity: 0.95;
  }

  .nav-menu a:hover {
    color: var(--pink-accent-1);
    transform: translateY(-2px);
  }

  .nav-menu a:hover::after,
  .nav-menu a:focus::after {
    transform: scaleX(1);
  }

  .nav-cta { display: flex; align-items: center; gap: 12px; }

  .btn-book {
    background: var(--accent-gradient);
    border: none;
    color: var(--white-pure);
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 22px rgba(122, 184, 255, 0.12);
    transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
  }

  .btn-book:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); opacity: 0.98; }

  .nav-toggle {
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(4, 32, 52, 0.06);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    cursor: pointer;
    display: none;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 600;
    padding: 10px 14px;
    transition: background 0.2s;
  }

  .nav-toggle:hover {
    background: rgba(255, 255, 255, 0.95);
  }

  /* ═══════════════════════════════════════════
     PAGE HERO (default inner pages)
  ═══════════════════════════════════════════ */
  .page-hero {
    background: linear-gradient(180deg, var(--ivory-bg) 0%, transparent 100%);
    color: var(--text-primary);
    padding-top: 48px;
    padding-bottom: 48px;
    position: relative;
    overflow: visible;
  }

  /* Home hero split layout */
  .page-hero--home .page-hero__inner {
    display: grid;
    grid-template-columns: 1fr 520px;
    gap: 40px;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 48px 22px;
  }

  .page-hero__content {
    padding: 18px 12px;
  }

  .page-hero__content h1 {
    color: var(--text-primary);
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.05;
    margin-bottom: 14px;
  }

  .page-hero__content p { color: var(--text-secondary); font-size: 1.05rem; margin-bottom: 18px; }

  .hero-actions { display: flex; gap: 14px; align-items: center; margin-top: 18px; }

  .button.button-primary {
    background: var(--accent-gradient);
    color: var(--white-pure);
    padding: 12px 18px;
    border-radius: var(--radius-pill);
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(122,184,255,0.10);
  }

  .button.button-secondary {
    background: transparent;
    border: 1px solid var(--border-soft);
    color: var(--text-primary);
    padding: 10px 16px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
  }

  .page-hero__media {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-hero__image {
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
    width: 100%;
    height: auto;
    display: block;
    border: 8px solid rgba(255,255,255,0.6);
    background: linear-gradient(135deg, rgba(255,126,182,0.06), rgba(122,184,255,0.03));
  }

  .page-hero__image { max-width: 520px; }

  .hero-highlights {
    display: flex;
    gap: 12px;
    margin-top: 18px;
    flex-wrap: wrap;
  }

  .hero-highlights span {
    background: var(--light-blue-bg);
    padding: 8px 12px;
    border-radius: 12px;
    font-weight: 700;
    color: var(--text-primary);
    font-size: 0.9rem;
  }

  /* ═══════════════════════════════════════════
     FOOTER - PREMIUM, DEEP NAVY WITH PINK HIGHLIGHTS
     Multiple columns, contact info, quick links, logos
  ═══════════════════════════════════════════ */
  .site-footer {
    background: linear-gradient(180deg, var(--navy-blue), #052033);
    color: var(--white-pure);
    padding: 48px 22px;
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px 240px;
    gap: 28px;
    align-items: start;
  }

  .footer-school-name { font-weight: 800; font-size: 1.15rem; margin: 0 0 6px; }
  .footer-promise { margin: 0 0 8px; color: rgba(255,255,255,0.85); }

  .footer-contact strong, .footer-links strong { display: block; margin-bottom: 8px; color: rgba(255,255,255,0.98); }
  .footer-contact a { color: var(--light-pink); display: inline-block; text-decoration: none; margin-bottom: 6px; }
  .footer-contact span { display: block; margin-top: 6px; color: rgba(255,255,255,0.85); }

  .footer-links a { display: block; color: rgba(255,255,255,0.9); text-decoration: none; margin-bottom: 6px; }
  .footer-links a:hover { color: var(--pink-accent-1); }

  .site-footer .brand-mark { color: var(--white-pure); }
  .site-footer .brand-symbol { box-shadow: none; }

  @media (max-width: 980px) {
    .footer-container { grid-template-columns: 1fr; gap: 18px; }
    .page-hero--home .page-hero__inner { grid-template-columns: 1fr; }
  }

</style>