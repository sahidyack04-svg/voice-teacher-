{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "cleanUrls": true,
  "redirects": [
    { "source": "/services", "destination": "/our-programs", "permanent": true },
    { "source": "/admissions", "destination": "/find-us", "permanent": true },
    { "source": "/contact", "destination": "/find-us", "permanent": true },
    { "source": "/gallery", "destination": "/", "permanent": true },
    { "source": "/facilities", "destination": "/about", "permanent": true },
    { "source": "/sports-clubs", "destination": "/our-programs", "permanent": true },
    { "source": "/parent-resources", "destination": "/find-us", "permanent": true }
  ],
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/openapi.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
